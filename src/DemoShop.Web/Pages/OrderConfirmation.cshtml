@page "/order/confirmation/{orderId}"
@model DemoShop.Web.Pages.OrderConfirmationModel
@{
    ViewData["Title"] = "Order Confirmation";
}

@if (Model.Order is null)
{
    <div class="alert alert-warning" data-testid="order-not-found-message">Order not found.</div>
}
else
{
    <h1 class="mb-3" data-testid="order-confirmed-title">Order Confirmed</h1>
    <p class="mb-1"><strong>Order ID:</strong> <span data-testid="order-id">@Model.Order.OrderId</span></p>
    <p><strong>Total:</strong> <span data-testid="order-total">$@Model.Order.Total.ToString("F2")</span></p>

    <section class="mt-4">
        <h2 class="h5">Items</h2>
        @foreach (var item in Model.Order.Items)
        {
            <article class="card mb-3" data-testid="order-item-@item.ProductId">
                <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <div data-testid="order-item-name-@item.ProductId">@item.Name</div>
                        <div class="text-muted" data-testid="order-item-qty-@item.ProductId">Qty: @item.Quantity</div>
                    </div>
                    <div class="fw-semibold" data-testid="order-item-line-total-@item.ProductId">$@((item.Price * item.Quantity).ToString("F2"))</div>
                </div>
            </article>
        }
    </section>

    <a class="btn btn-primary mt-3" href="/products" data-testid="continue-shopping-link">Continue Shopping</a>
}
