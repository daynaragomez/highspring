@page
@model DemoShop.Web.Pages.ProductsModel
@{
    ViewData["Title"] = "Products";
}

<h1 class="mb-4" data-testid="products-page-title">Products</h1>

<section class="products-list">
    <div class="row g-4">
    @foreach (var product in Model.Products)
    {
        <div class="col-12 col-md-6 col-lg-4">
            <article class="card h-100" data-testid="product-card-@product.Id">
                <div class="card-body d-flex flex-column">
                    <h2 class="card-title h5" data-testid="product-name-@product.Id">@product.Name</h2>
                    <p class="card-text text-muted mb-4" data-testid="product-price-@product.Id">$@product.Price.ToString("F2")</p>
                    <a class="btn btn-primary mt-auto" data-testid="view-product-@product.Id" href="/products/@product.Id">View</a>
                </div>
            </article>
        </div>
    }
    </div>
</section>
