@page "/products/{id:int}"
@model DemoShop.Web.Pages.ProductDetailsModel
@{
    ViewData["Title"] = "Product Details";
}

<h1 data-testid="product-details-page-title">Product Details</h1>

@if (Model.Product is not null)
{
    <section class="mb-4">
        <h2 data-testid="product-details-name">@Model.Product.Name</h2>
        <p class="text-muted" data-testid="product-details-price">$@Model.Product.Price.ToString("F2")</p>
    </section>

    <form method="post" class="mt-4">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Quantity" class="form-label">Quantity</label>
            <input asp-for="Quantity" class="form-control" type="number" min="1" data-testid="quantity-input" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary" data-testid="add-to-cart-button">Add to Cart</button>
    </form>
}
