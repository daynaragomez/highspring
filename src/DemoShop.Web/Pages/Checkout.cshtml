@page "/checkout"
@model DemoShop.Web.Pages.CheckoutModel
@{
    ViewData["Title"] = "Checkout";
}

<h1 class="mb-4">Checkout</h1>

@if (!Model.CartItems.Any())
{
    <div class="alert alert-info" data-testid="checkout-empty-cart-message">Your cart is empty.</div>
    <a class="btn btn-primary" href="/products" data-testid="checkout-back-to-products">Back to Products</a>
}
else
{
    <div class="row g-4">
        <div class="col-12 col-lg-7">
            <form method="post" class="card card-body">
                <div class="mb-3 text-danger" asp-validation-summary="ModelOnly" data-testid="checkout-validation-summary"></div>

                <div class="mb-3">
                    <label asp-for="Input.FullName" class="form-label"></label>
                    <input asp-for="Input.FullName" class="form-control" data-testid="checkout-fullname" />
                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control" data-testid="checkout-email" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Phone" class="form-label"></label>
                    <input asp-for="Input.Phone" class="form-control" data-testid="checkout-phone" />
                    <span asp-validation-for="Input.Phone" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.AddressLine1" class="form-label"></label>
                    <input asp-for="Input.AddressLine1" class="form-control" data-testid="checkout-address1" />
                    <span asp-validation-for="Input.AddressLine1" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.AddressLine2" class="form-label"></label>
                    <input asp-for="Input.AddressLine2" class="form-control" data-testid="checkout-address2" />
                    <span asp-validation-for="Input.AddressLine2" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.City" class="form-label"></label>
                    <input asp-for="Input.City" class="form-control" data-testid="checkout-city" />
                    <span asp-validation-for="Input.City" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.PostalCode" class="form-label"></label>
                    <input asp-for="Input.PostalCode" class="form-control" data-testid="checkout-postal" />
                    <span asp-validation-for="Input.PostalCode" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label d-block">Shipping Method</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" id="shipping-standard" name="Input.ShippingMethod" value="Standard" @(Model.Input.ShippingMethod == "Standard" ? "checked" : string.Empty) data-testid="checkout-shipping-standard" />
                        <label class="form-check-label" for="shipping-standard">Standard (Free)</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" id="shipping-express" name="Input.ShippingMethod" value="Express" @(Model.Input.ShippingMethod == "Express" ? "checked" : string.Empty) data-testid="checkout-shipping-express" />
                        <label class="form-check-label" for="shipping-express">Express ($9.99)</label>
                    </div>
                    <span asp-validation-for="Input.ShippingMethod" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label d-block">Payment Method</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" id="payment-card" name="Input.PaymentMethod" value="Card" @(Model.Input.PaymentMethod == "Card" ? "checked" : string.Empty) data-testid="checkout-payment-card" />
                        <label class="form-check-label" for="payment-card">Card</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" id="payment-cod" name="Input.PaymentMethod" value="CashOnDelivery" @(Model.Input.PaymentMethod == "CashOnDelivery" ? "checked" : string.Empty) data-testid="checkout-payment-cod" />
                        <label class="form-check-label" for="payment-cod">Cash on Delivery</label>
                    </div>
                    <span asp-validation-for="Input.PaymentMethod" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary" data-testid="place-order-button">Place Order</button>
            </form>
        </div>
        <div class="col-12 col-lg-5">
            <div class="card">
                <div class="card-body">
                    <h2 class="h5">Order Summary</h2>
                    <ul class="list-group list-group-flush mb-3">
                    @foreach (var item in Model.CartItems)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>@($"{item.Name} (x{item.Quantity})")</span>
                            <span>$@((item.Price * item.Quantity).ToString("F2"))</span>
                        </li>
                    }
                    </ul>
                    <div class="d-flex justify-content-between">
                        <span>Subtotal</span>
                        <strong data-testid="checkout-subtotal">$@Model.Subtotal.ToString("F2")</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Shipping</span>
                        <strong data-testid="checkout-shipping-cost">$@Model.ShippingCost.ToString("F2")</strong>
                    </div>
                    <div class="d-flex justify-content-between fs-5 mt-2">
                        <span>Total</span>
                        <strong data-testid="checkout-total">$@Model.Total.ToString("F2")</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
