@page "/cart"
@model DemoShop.Web.Pages.CartModel
@{
    ViewData["Title"] = "Cart";
}

<h1 class="mb-4">Cart</h1>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

@if (!Model.CartItems.Any())
{
    <p data-testid="empty-cart-message">Your cart is empty.</p>
}
else
{
    <section class="cart-items">
    @foreach (var item in Model.CartItems)
    {
        <article class="card mb-3" data-testid="cart-item-@item.ProductId">
            <div class="card-body row g-3 align-items-center">
                <div class="col-12 col-md-4">
                    <h2 class="h5" data-testid="cart-item-name-@item.ProductId">@item.Name</h2>
                    <p class="text-muted mb-1" data-testid="cart-item-price-@item.ProductId">$@item.Price.ToString("F2")</p>
                </div>
                <div class="col-12 col-md-4">
                    <form method="post" asp-page-handler="Update" class="d-flex gap-2 align-items-center">
                        <input type="hidden" name="productId" value="@item.ProductId" />
                        <label class="visually-hidden" for="qty-@item.ProductId">Quantity</label>
                        <input id="qty-@item.ProductId" class="form-control" type="number" min="1" name="quantity" value="@item.Quantity" data-testid="cart-quantity-@item.ProductId" />
                        <button type="submit" class="btn btn-outline-primary">Update</button>
                    </form>
                </div>
                <div class="col-12 col-md-2">
                    <p class="fw-semibold" data-testid="cart-line-total-@item.ProductId">$@((item.Price * item.Quantity).ToString("F2"))</p>
                </div>
                <div class="col-12 col-md-2 text-md-end">
                    <form method="post" asp-page-handler="Remove">
                        <input type="hidden" name="productId" value="@item.ProductId" />
                        <button type="submit" class="btn btn-link text-danger" data-testid="remove-item-@item.ProductId">Remove</button>
                    </form>
                </div>
            </div>
        </article>
    }
    </section>

    <section class="card mt-4">
        <div class="card-body d-flex flex-column flex-md-row align-items-md-center justify-content-between">
            <div class="mb-3 mb-md-0">
                <span class="text-muted">Subtotal</span>
                <div class="fs-4" data-testid="cart-subtotal">$@Model.Subtotal.ToString("F2")</div>
            </div>
            <a class="btn btn-success" href="/checkout" data-testid="proceed-to-checkout-button">Proceed to Checkout</a>
        </div>
    </section>
}