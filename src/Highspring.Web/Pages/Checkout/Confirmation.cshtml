@page "/checkout/confirmation/{orderId:guid}"
@model Highspring.Web.Pages.Checkout.ConfirmationModel
@{
    ViewData["Title"] = "Order Confirmation";
}

@if (Model.Order is null)
{
    <section data-testid="page-checkout-confirmation">
        <p class="text-sm text-slate-600">Order not found.</p>
    </section>
}
else
{
    <section class="space-y-6" data-testid="page-checkout-confirmation">
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 p-6">
            <h1 class="text-2xl font-bold text-emerald-900">Order confirmed</h1>
            <p class="mt-2 text-sm text-emerald-800">Thanks for your purchase. Your order has been placed successfully.</p>
            <p class="mt-3 text-sm text-slate-700">Order ID: <strong data-testid="order-confirmation-id">@Model.Order.Id</strong></p>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
            <div class="space-y-3 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
                <h2 class="text-lg font-semibold">Items</h2>
                @foreach (var item in Model.Order.Items)
                {
                    <div class="flex items-center justify-between border-b border-slate-100 pb-2 text-sm">
                        <div>
                            <p class="font-medium">@item.ProductName</p>
                            <p class="text-slate-500">@item.ProductSku · Qty @item.Quantity</p>
                        </div>
                        <span class="font-semibold">$@item.LineTotal.ToString("0.00")</span>
                    </div>
                }
            </div>

            <aside class="space-y-2 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm text-sm">
                <div class="flex items-center justify-between">
                    <span class="text-slate-600">Subtotal</span>
                    <span data-testid="subtotal-value" class="font-semibold">$@Model.Order.Subtotal.ToString("0.00")</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-slate-600">Discount</span>
                    <span data-testid="discount-total" class="font-semibold">$@Model.Order.DiscountTotal.ToString("0.00")</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-slate-600">Tax</span>
                    <span data-testid="tax-total" class="font-semibold">$@Model.Order.TaxTotal.ToString("0.00")</span>
                </div>
                <div class="flex items-center justify-between border-t border-slate-200 pt-2 text-base font-bold">
                    <span>Total</span>
                    <span data-testid="order-total">$@Model.Order.GrandTotal.ToString("0.00")</span>
                </div>
            </aside>
        </div>
    </section>
}
