@page
@model IndexModel
@{
    ViewData["Title"] = "Ecommerce Demo";
}

<section class="space-y-10">
    <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="max-w-3xl space-y-4">
            <p class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-slate-600">New Collection</p>
            <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">A modern ecommerce demo built with ASP.NET Core Razor Pages</h1>
            <p class="text-base leading-relaxed text-slate-600">Explore a clean storefront layout, fast server-rendered pages, and container-ready architecture powered by .NET 10.</p>
            <div class="flex flex-wrap items-center gap-3 pt-2">
                <a href="#products" class="rounded-lg bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800">Shop now</a>
                <a href="/health" class="rounded-lg border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100">Health check</a>
            </div>
        </div>
    </div>

    <div id="products" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">Classic Hoodie</h2>
            <p class="mt-2 text-sm text-slate-600">Everyday comfort with premium cotton blend and minimal style.</p>
            <p class="mt-4 text-xl font-bold text-slate-900">$49.00</p>
            <button class="mt-4 w-full rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">Add to cart</button>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">Urban Sneakers</h2>
            <p class="mt-2 text-sm text-slate-600">Lightweight cushioning and modern silhouette for daily wear.</p>
            <p class="mt-4 text-xl font-bold text-slate-900">$89.00</p>
            <button class="mt-4 w-full rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">Add to cart</button>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">Travel Backpack</h2>
            <p class="mt-2 text-sm text-slate-600">Organized compartments and durable fabric for city adventures.</p>
            <p class="mt-4 text-xl font-bold text-slate-900">$64.00</p>
            <button class="mt-4 w-full rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">Add to cart</button>
        </article>
    </div>
</section>
