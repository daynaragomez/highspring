@page "/products"
@model Highspring.Web.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
}

<section class="space-y-6" data-testid="page-products">
    <div class="flex items-end justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">Products</h1>
            <p class="mt-2 text-sm text-slate-600">Deterministic catalog for automation scenarios.</p>
        </div>
        <a asp-page="/Cart/Index" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold hover:bg-slate-100">View cart</a>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        @foreach (var product in Model.Products)
        {
            <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" data-testid="product-card-@product.Sku">
                <h2 class="text-lg font-semibold text-slate-900">@product.Name</h2>
                <p class="mt-2 text-sm text-slate-500">SKU: @product.Sku</p>
                <p class="mt-4 text-xl font-bold text-slate-900">$@product.Price.ToString("0.00")</p>
                <p class="mt-1 text-sm text-slate-600">Stock: @product.StockQuantity</p>

                <div class="mt-4 flex gap-3">
                    <a asp-page="/Products/Details" asp-route-sku="@product.Sku" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100">Details</a>
                    <form method="post" asp-page-handler="AddToCart" class="flex-1">
                        <input type="hidden" name="sku" value="@product.Sku" />
                        <input type="hidden" name="quantity" value="1" />
                        <button type="submit" class="w-full rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800" data-testid="add-to-cart-@product.Sku">Add to cart</button>
                    </form>
                </div>
            </article>
        }
    </div>
</section>
