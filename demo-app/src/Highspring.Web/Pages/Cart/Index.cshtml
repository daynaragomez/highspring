@page "/cart"
@model Highspring.Web.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Cart";
}

<section class="space-y-6" data-testid="page-cart">
    <div class="flex items-end justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">Your Cart</h1>
            <p class="mt-2 text-sm text-slate-600">Review items, apply discount, and proceed to checkout.</p>
        </div>
        <a asp-page="/Products/Index" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold hover:bg-slate-100">Continue shopping</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@Model.ErrorMessage</div>
    }

    @if (Model.Snapshot.Cart.Items.Count == 0)
    {
        <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center text-slate-600">
            Your cart is empty.
        </div>
    }
    else
    {
        <div class="grid gap-6 lg:grid-cols-3">
            <div class="space-y-4 lg:col-span-2">
                @foreach (var item in Model.Snapshot.Cart.Items)
                {
                    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm" data-testid="cart-line-@item.ProductSku">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <h2 class="text-lg font-semibold text-slate-900">@item.ProductName</h2>
                                <p class="mt-1 text-sm text-slate-500">@item.ProductSku</p>
                                <p class="mt-2 text-sm text-slate-700">$@item.UnitPriceSnapshot.ToString("0.00") each</p>
                            </div>
                            <form method="post" asp-page-handler="RemoveItem">
                                <input type="hidden" name="sku" value="@item.ProductSku" />
                                <button type="submit" class="text-sm font-semibold text-slate-600 hover:text-slate-900">Remove</button>
                            </form>
                        </div>

                        <form method="post" asp-page-handler="UpdateQuantity" class="mt-4 flex items-center gap-3">
                            <input type="hidden" name="sku" value="@item.ProductSku" />
                            <label class="text-sm text-slate-700" for="qty-@item.ProductSku">Qty</label>
                            <input id="qty-@item.ProductSku" data-testid="qty-input-@item.ProductSku" name="quantity" min="0" value="@item.Quantity" type="number" class="w-20 rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                            <button type="submit" class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-semibold hover:bg-slate-100">Update</button>
                        </form>
                    </article>
                }
            </div>

            <aside class="space-y-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <h2 class="text-lg font-semibold">Summary</h2>

                <form method="post" asp-page-handler="ApplyCoupon" class="space-y-3">
                    <label class="block text-sm font-medium text-slate-700" for="couponCode">Coupon code</label>
                    <input id="couponCode" data-testid="apply-discount-input" name="CouponCode" value="@Model.Snapshot.AppliedCouponCode" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                    <button type="submit" data-testid="apply-discount-button" class="w-full rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold hover:bg-slate-100">Apply discount</button>
                </form>

                <dl class="space-y-2 text-sm">
                    <div class="flex items-center justify-between">
                        <dt class="text-slate-600">Subtotal</dt>
                        <dd class="font-semibold" data-testid="subtotal-value">$@Model.Snapshot.Pricing.Subtotal.ToString("0.00")</dd>
                    </div>
                    <div class="flex items-center justify-between">
                        <dt class="text-slate-600">Discount</dt>
                        <dd class="font-semibold" data-testid="discount-total">$@Model.Snapshot.Pricing.DiscountTotal.ToString("0.00")</dd>
                    </div>
                    <div class="flex items-center justify-between">
                        <dt class="text-slate-600">Tax</dt>
                        <dd class="font-semibold" data-testid="tax-total">$@Model.Snapshot.Pricing.TaxTotal.ToString("0.00")</dd>
                    </div>
                    <div class="flex items-center justify-between border-t border-slate-200 pt-2 text-base">
                        <dt class="font-semibold text-slate-900">Total</dt>
                        <dd class="font-bold text-slate-900" data-testid="order-total">$@Model.Snapshot.Pricing.GrandTotal.ToString("0.00")</dd>
                    </div>
                </dl>

                <a asp-page="/Checkout/Index" class="block w-full rounded-lg bg-slate-900 px-4 py-2 text-center text-sm font-semibold text-white hover:bg-slate-800">Proceed to checkout</a>
            </aside>
        </div>
    }
</section>
